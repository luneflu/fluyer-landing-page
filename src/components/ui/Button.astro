---
import type { GlassShineSize } from "../../types/glass";
import View from "./View.astro";

interface Props {
  class?: string;
  glassShineSize?: GlassShineSize;
  [key: string]: any;
}

const { class: className = "", glassShineSize, onclick, ...rest } = Astro.props;

const clickScript = `
	const el = this;
	el.classList.remove('scale-100');
	el.classList.add('scale-95');
	setTimeout(() => {
		el.classList.remove('scale-95');
		el.classList.add('scale-100');
	}, 100);
	${onclick ? `setTimeout(() => { ${onclick} }, 200);` : ""}
`;
---

<View
  class={`cursor-pointer scale-100 transition-transform ${className}`}
  glassShineSize={glassShineSize}
  glassEnableHoverEffect={true}
  onclick={clickScript}
  {...rest}
>
  <slot />
</View>
