---
import View from "./ui/View.astro";

const formats = [
    "mp3",
    "flac",
    "wav",
    "ogg",
    "m4a",
    "m4b",
    "mp4",
    "mkv",
    "webm",
    "avi",
    "aac",
    "wma",
    "opus",
    "alac",
    "ape",
    "aiff",
    "mov",
    "ts",
    "flv",
    "3gp",
    "wmv",
];

const features = [
    {
        title: "Auto Organized Library",
        description:
            "Tracks and albums are sorted automatically, so your collection stays clean without work",
    },
    {
        title: "Gapless Playback",
        description: "Continuous audio between tracks",
    },
    {
        title: "High Quality Audio Support",
        description: "Support audio quality up to 32-bit/192 kHz",
    },
    {
        title: "Automatic Cover Art",
        description: "Album artwork retrieved from ",
        link: { label: "MusicBrainz", href: "https://musicbrainz.org/" },
    },
    {
        title: "Cross Platform",
        description: "Runs on Windows, macOS, Linux, and Android",
    },
    {
        title: "Free & Open Source",
        description: "Hosted under MIT License on ",
        link: { label: "GitHub", href: "https://github.com/luneflu/Fluyer" },
    },
];
---

<section id="features-section" class="w-full max-w-5xl mx-auto px-6 py-10">
    <header class="mb-10 md:mb-14 text-center">
        <h2 class="font-bold text-3xl mb-3">Features</h2>
        <p class="text-base md:text-lg max-w-2xl mx-auto leading-relaxed">
            Our app uses the <a
                class="font-semibold text-white underline"
                href="https://www.un4seen.com">BASS library</a
            > as both player and decoder, and <a
                class="font-semibold text-white underline"
                href="https://www.ffmpeg.org">FFmpeg</a
            > as decoder. So by default it supports lot of audio formats and is able
            to play <span class="font-semibold text-white"
                >high quality audio</span
            >.
        </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
        {
            features.map((feature) => {
                return (
                    <View class="group relative overflow-hidden rounded-2xl bg-white/4 hover:bg-white/7 border border-white/10 hover:border-white/20 p-5 md:p-6 transition-all duration-300">
                        <div class="absolute -top-12 -right-12 w-32 h-32 rounded-full bg-linear-to-br from-violet-500/10 to-fuchsia-500/10 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                        <div class="relative flex items-start gap-4">
                            <div class="flex-1 min-w-0">
                                <h3 class="text-lg font-semibold text-white mb-1">
                                    {feature.title}
                                </h3>
                                <p class="text-sm text-white/80 leading-relaxed">
                                    {feature.description}
                                    {feature.link && (
                                        <a
                                            href={feature.link.href}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="underline"
                                        >
                                            {feature.link.label}
                                        </a>
                                    )}
                                </p>
                            </div>
                        </div>
                    </View>
                );
            })
        }
    </div>

    <section
        class="mt-6 md:mt-5 rounded-2xl bg-white/4 border border-white/10 p-5 md:p-6"
    >
        <div class="flex items-start gap-4 mb-4">
            <div class="flex-1">
                <h3 class="text-lg font-semibold text-white mb-1">
                    Supported Formats
                </h3>
                <p class="text-sm text-white/65">
                    Wide range of audio and video formats, not all fully tested
                    yet.
                </p>
            </div>
        </div>
        <div class="flex flex-wrap gap-2">
            {
                formats.map((format) => (
                    <span class="px-3 py-1 text-xs font-mono font-medium rounded-full bg-white/6 hover:bg-white/12 border border-white/10 hover:border-white/20 text-white/80 hover:text-white transition-colors">
                        {format}
                    </span>
                ))
            }
        </div>
    </section>
</section>
