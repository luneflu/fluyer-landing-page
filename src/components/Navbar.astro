---
import { Image } from "astro:assets";
import appIcon from "../assets/icon.png";
import Button from "./ui/Button.astro";
---

<nav
  transition:persist
  class="w-full z-50 px-6 py-3 md:p-6 flex flex-col md:flex-row md:items-center justify-between"
>
  <div class="flex items-center justify-between w-full md:w-auto">
    <a href="/" class="flex items-center gap-4">
      <Image
        src={appIcon}
        alt="App Icon"
        class="w-10 h-10 md:w-12 md:h-12 rounded-lg shadow-[0_4px_12px_rgba(0,0,0,0.1)]"
      />
      <h1 class="text-3xl md:text-4xl font-semibold m-0">Fluyer</h1>
    </a>
    <button
      id="mobile-menu-toggle"
      class="md:hidden focus:outline-none font-medium"
    >
      <!-- I'll add icon later placeholder -->
      <span>[Menu]</span>
    </button>
  </div>

  <div
    id="nav-links"
    class="hidden md:flex flex-col md:flex-row items-start md:items-center gap-4 mt-6 md:mt-0"
  >
    <a href="/download"><Button class="rounded px-3 py-2">Downloads</Button></a>
  </div>
</nav>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const links = document.getElementById("nav-links");

  toggle?.addEventListener("click", () => {
    links?.classList.toggle("hidden");
    links?.classList.toggle("flex");
  });
</script>
