---
import { Image } from "astro:assets";
import appIcon from "../assets/icon.png";
import Button from "./ui/Button.astro";
---

<nav
  transition:persist
  class="w-full z-50 px-6 py-3 md:p-6 flex items-center justify-between"
>
  <a href="/" class="flex items-center gap-4">
    <Image
      src={appIcon}
      alt="App Icon"
      class="w-10 h-10 md:w-12 md:h-12 rounded-lg shadow-[0_4px_12px_rgba(0,0,0,0.1)]"
    />
    <h1 class="text-3xl md:text-4xl font-semibold m-0">Fluyer</h1>
  </a>

  <div class="flex items-center gap-3">
    <a
      class="w-10 h-10"
      href="https://discord.gg/ASbvZa7Dj"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Discord"
    >
      <img
        class="invert"
        src="https://img.icons8.com/ios-glyphs/90/discord-logo.png"
        alt="Discord"
      />
    </a>
    <a
      class="w-10 h-10"
      href="https://github.com/luneflu/Fluyer"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
    >
      <img
        class="invert"
        src="https://img.icons8.com/ios-glyphs/90/github.png"
        alt="GitHub"
      />
    </a>
  </div>
</nav>
